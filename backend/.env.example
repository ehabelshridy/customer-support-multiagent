# LLM provider: "huggingface" (default) or "openai"
LLM_PROVIDER=huggingface

# --- HuggingFace Inference API ---
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here
HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- OpenAI (only needed if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Business rules ---
ROUTING_CONFIDENCE_THRESHOLD=0.7
REFUND_AUTO_APPROVE_LIMIT=100
MAX_AGENT_RETRIES=2

# --- Paths (defaults are fine for local/docker runs) ---
DB_PATH=app/db/support_system.db
CHECKPOINT_DB_PATH=app/db/checkpoints.db
